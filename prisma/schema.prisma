generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountProvider {
  github
  linear
}

enum EntryType {
  update
  blocker
  status
}

enum EntrySource {
  manual
  dm
  github_commit
  github_pr
  linear_issue
}

enum SummarySessionStatus {
  pending
  completed
  expired
}

enum ScheduledJobStatus {
  idle
  running
  completed
  failed
}

model User {
  id               String    @id @default(cuid())
  slackUserId      String    @unique @map("slack_user_id")
  slackTeamId      String    @map("slack_team_id")
  remindersEnabled Boolean   @default(true) @map("reminders_enabled")
  reminderDays     String[]  @default(["mon", "tue", "wed", "thu", "fri"]) @map("reminder_days")
  reminderSlots    String[]  @default(["morning", "evening"]) @map("reminder_slots")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  dailySequences DailySequence[]
  logEntries     LogEntry[]
  projects       Project[]  @relation("OwnedProjects")
  reminderDeliveries ReminderDelivery[]
  summarySessions SummarySession[]

  @@map("users")
}

model DailySequence {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  dateKey             String   @map("date_key")
  nextLogDisplayId    Int      @default(1) @map("next_log_display_id")
  nextSummaryUpdateNo Int      @default(1) @map("next_summary_update_no")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@map("daily_sequences")
}

model Account {
  id                String          @id @default(cuid())
  userId            String          @map("user_id")
  provider          AccountProvider
  providerAccountId String          @map("provider_account_id")
  accessToken       String          @map("access_token")
  username          String?
  scope             String?
  metadata          Json?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Project {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  githubRepo          String    @map("github_repo")
  githubRepoUrl       String?   @map("github_repo_url")
  githubRepoId        String?   @map("github_repo_id")
  githubRepoUpdatedAt DateTime? @map("github_repo_updated_at")
  linearTeamId        String?   @map("linear_team_id")
  linearProjectId     String?   @map("linear_project_id")
  linearProjectName   String?   @map("linear_project_name")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  lastUsedAt          DateTime? @map("last_used_at")

  logEntries      LogEntry[]
  summarySessions SummarySession[]
  user            User          @relation("OwnedProjects", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, githubRepo])
  @@unique([userId, githubRepoId])
  @@map("projects")
}

model LogEntry {
  id          String      @id @default(cuid())
  displayId   Int         @map("display_id")
  displayDateKey String   @default("") @map("display_date_key")
  userId      String      @map("user_id")
  projectId   String?     @map("project_id")
  content     String
  entryType   EntryType   @map("entry_type")
  source      EntrySource @default(manual)
  title       String?
  externalId  String?     @map("external_id")
  externalUrl String?     @map("external_url")
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, displayDateKey, displayId])
  @@index([userId, createdAt])
  @@index([userId, deletedAt])
  @@index([projectId, createdAt])
  @@map("log_entries")
}

model SummarySession {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  projectId      String?              @map("project_id")
  channelId      String               @map("channel_id")
  period         String
  updateNo       Int                  @map("update_no")
  updateDateKey  String               @default("") @map("update_date_key")
  summaryPreview String?              @map("summary_preview")
  questions      Json                 @default("[]")
  answers        Json                 @default("[]")
  status         SummarySessionStatus @default(pending)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  expiresAt      DateTime             @map("expires_at")
  completedAt    DateTime?            @map("completed_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updateDateKey, updateNo])
  @@index([userId, status, expiresAt])
  @@index([userId, projectId, updateNo])
  @@map("summary_sessions")
}

model ReminderDelivery {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  reminderKey     String   @map("reminder_key")
  reminderDateKey String   @map("reminder_date_key")
  sentAt          DateTime @default(now()) @map("sent_at")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reminderKey, reminderDateKey])
  @@index([sentAt])
  @@map("reminder_deliveries")
}

model ScheduledJob {
  jobKey          String             @id @map("job_key")
  leaseToken      String?            @map("lease_token")
  leaseExpiresAt  DateTime?          @map("lease_expires_at")
  lastStartedAt   DateTime?          @map("last_started_at")
  lastCompletedAt DateTime?          @map("last_completed_at")
  lastStatus      ScheduledJobStatus @default(idle) @map("last_status")
  lastError       String?            @map("last_error")
  lastSummary     Json?              @map("last_summary")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("scheduled_jobs")
}

model LinkToken {
  id          String   @id @default(cuid())
  slackUserId String   @map("slack_user_id")
  slackTeamId String   @map("slack_team_id")
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("link_tokens")
}
