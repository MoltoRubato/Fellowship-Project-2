generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountProvider {
  github
  linear
}

enum EntryType {
  update
  blocker
  status
}

enum IntegrationType {
  linear
}

enum EntrySource {
  manual
  dm
  github_commit
  github_pr
  linear_issue
}

enum SummarySessionStatus {
  pending
  completed
  expired
}

model User {
  id               String    @id @default(cuid())
  slackUserId      String    @unique @map("slack_user_id")
  slackTeamId      String    @map("slack_team_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  logEntries     LogEntry[]
  projects       Project[]  @relation("OwnedProjects")
  summarySessions SummarySession[]

  @@map("users")
}

model Account {
  id                String          @id @default(cuid())
  userId            String          @map("user_id")
  provider          AccountProvider
  providerAccountId String          @map("provider_account_id")
  accessToken       String          @map("access_token")
  username          String?
  scope             String?
  metadata          Json?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Project {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  githubRepo        String    @map("github_repo")
  githubRepoUrl     String?   @map("github_repo_url")
  githubRepoId      String?   @map("github_repo_id")
  githubRepoUpdatedAt DateTime? @map("github_repo_updated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastUsedAt        DateTime? @map("last_used_at")

  integrations ProjectIntegration[]
  logEntries   LogEntry[]
  summarySessions SummarySession[]
  user         User                 @relation("OwnedProjects", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, githubRepo])
  @@unique([userId, githubRepoId])
  @@map("projects")
}

model ProjectIntegration {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  type           IntegrationType
  externalId     String?         @map("external_id")
  externalName   String?         @map("external_name")
  externalTeamId String?         @map("external_team_id")
  config         Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@map("project_integrations")
}

model LogEntry {
  id          String      @id @default(cuid())
  displayId   Int         @unique @default(autoincrement()) @map("display_id")
  userId      String      @map("user_id")
  projectId   String?     @map("project_id")
  content     String
  entryType   EntryType   @map("entry_type")
  source      EntrySource @default(manual)
  title       String?
  externalId  String?     @map("external_id")
  externalUrl String?     @map("external_url")
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, deletedAt])
  @@index([projectId, createdAt])
  @@map("log_entries")
}

model SummarySession {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  projectId      String?              @map("project_id")
  channelId      String               @map("channel_id")
  period         String
  updateNo       Int                  @map("update_no")
  summaryPreview String?              @map("summary_preview")
  questions      Json                 @default("[]")
  answers        Json                 @default("[]")
  status         SummarySessionStatus @default(pending)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  expiresAt      DateTime             @map("expires_at")
  completedAt    DateTime?            @map("completed_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@index([userId, projectId, updateNo])
  @@map("summary_sessions")
}

model LinkToken {
  id          String   @id @default(cuid())
  slackUserId String   @map("slack_user_id")
  slackTeamId String   @map("slack_team_id")
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  used        Boolean  @default(false)
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("link_tokens")
}
