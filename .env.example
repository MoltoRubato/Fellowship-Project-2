# App
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NODE_ENV=development

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Optional when using Socket Mode locally.
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Scheduled jobs and webhook verification
CRON_SECRET=replace-me-with-a-long-random-string
GITHUB_WEBHOOK_SECRET=replace-me-with-a-long-random-string
LINEAR_WEBHOOK_SECRET=replace-me-with-a-long-random-string

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/standup_bot

# OAuth
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
LINEAR_CLIENT_ID=your-linear-oauth-app-client-id
LINEAR_CLIENT_SECRET=your-linear-oauth-app-client-secret

# AI
GOOGLE_AI_API_KEY=your-google-ai-studio-api-key
# Optional override. Defaults to gemini-2.5-flash.
GOOGLE_AI_MODEL=gemini-2.5-flash

# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-here

# Optional retention overrides (days)
# RETENTION_USED_LINK_TOKENS_DAYS=2
# RETENTION_EXPIRED_LINK_TOKENS_DAYS=7
# RETENTION_PENDING_SUMMARY_DAYS=7
# RETENTION_COMPLETED_SUMMARY_DAYS=45
# RETENTION_EXTERNAL_LOG_DAYS=45
# RETENTION_MANUAL_LOG_DAYS=180
# RETENTION_DELETED_LOG_DAYS=30
# RETENTION_REMINDER_DELIVERY_DAYS=30
