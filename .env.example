# App
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NODE_ENV=development

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/standup_bot

# OAuth
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
LINEAR_CLIENT_ID=your-linear-oauth-app-client-id
LINEAR_CLIENT_SECRET=your-linear-oauth-app-client-secret

# AI
GOOGLE_AI_API_KEY=your-google-ai-studio-api-key
# Optional override. Defaults to gemini-2.5-flash.
GOOGLE_AI_MODEL=gemini-2.5-flash

# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-here
